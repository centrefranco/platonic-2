---
import Schema from '@components/universal/shared/v1/meta/Schema.astro'
import Layout from '@layouts/Layout.astro'
import Socials from '@components/Socials.astro'
import { getDecapCollection } from '@lib/AstroDecap'

export async function getStaticPaths() {
  const items = await getDecapCollection('items')

  return Array.isArray(items)
    ? items.map((item) => ({
        params: { id: item.id },
        props: { resource: item },
      }))
    : [{ params: { id: items.id }, props: { resource: items } }]
}

const { resource } = Astro.props
---

<Layout title={resource.value} debug={{ resource }}>
  <main class="bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div
        class="lg:grid lg:grid-cols-2 lg:gap-x-8 lg:items-start animate-fade-in"
      >
        <div class="flex flex-col items-center animate-fade-in-delay-50">
          <div
            class="overflow-hidden rounded-lg bg-gray-100 shadow-lg transition-all duration-300 hover:shadow-xl transform hover:-translate-y-1"
          >
            <img
              src={resource?.imageSrc}
              alt={resource?.imageAlt}
              class="h-full w-full object-cover object-center"
            />
          </div>

          <div class="mt-6 animate-fade-in-delay-800">
            <h3 class="text-sm font-medium text-gray-900 mb-2">Share</h3>
            <Socials />
          </div>
        </div>

        <div class="mt-10 px-4 sm:px-0 sm:mt-16 lg:mt-0">
          <h1
            class="text-3xl font-bold tracking-tight text-gray-900 animate-fade-in-delay-100"
          >
            {resource?.value}
          </h1>

          <div class="mt-3 animate-fade-in-delay-200">
            <p class="text-3xl tracking-tight text-gray-900">
              {resource?.price}
            </p>
          </div>

          <div class="mt-6">
            <div class="space-y-6 text-base text-gray-700">
              <div class="flex items-center animate-fade-in-delay-300">
                <span class="font-medium text-gray-900 mr-2">Code:</span>
                <span>{resource?.code}</span>
              </div>

              <div class="flex items-center animate-fade-in-delay-400">
                <span class="font-medium text-gray-900 mr-2">Color:</span>
                <span class="capitalize">{resource?.color}</span>
                <div
                  class="ml-2 h-4 w-4 rounded-full border border-gray-300 bg-[color:var(--color)]"
                  style={`color: ${resource?.color}`}
                  aria-hidden="true"
                >
                </div>
              </div>

              <div class="flex items-center animate-fade-in-delay-500">
                <span class="font-medium text-gray-900 mr-2">Size:</span>
                <span class="uppercase">{resource?.size}</span>
              </div>
            </div>
          </div>

          <div class="mt-6 animate-fade-in-delay-700">
            <div class="text-sm text-gray-500">
              <span class="font-medium text-gray-900 mr-2">ID:</span>
              <span class="uppercase">{resource?.id}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Schema
    course-name={resource?.value}
    course-code={resource?.code}
    keywords={resource?.value}
    image-url={resource?.imageSrc}
    language="fr-CA"
    orgUrl="https://www.apprentissageenligne.org/"
    orgName="Consortium d'apprentissage virtuel de langue française de l'Ontario"
  />
</Layout>
