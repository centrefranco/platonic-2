---
import Layout from '@layouts/Layout.astro'
import { getCollection } from 'astro:content'

const documents = await getCollection('documents')
---

<Layout title="Documentation" debug={{ documents }}>
  <div class="flex min-h-full flex-col">
    <main class="flex-1">
      <!-- Hero Section -->
      <div class="bg-gradient-to-b from-blue-50 to-white">
        <div class="mx-auto max-w-7xl px-4 pt-20 pb-10 sm:px-6 lg:px-8">
          <div class="text-center">
            <h1
              class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl"
            >
              <span class="block">Platonic Documentation</span>
            </h1>
            <p
              class="mx-auto mt-3 max-w-md text-base text-gray-500 sm:text-lg md:mt-5 md:max-w-3xl md:text-xl"
            >
              Everything you need to know about using Astro with Decap CMS and
              building amazing websites.
            </p>
          </div>
        </div>
      </div>

      <!-- Card Section -->
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div
            class="transform transition duration-500 hover:scale-105 hover:shadow-xl"
          >
            <a
              href="/documentation/why-platonic"
              class="flex flex-col overflow-hidden rounded-3xl shadow-md group"
            >
              <div class="relative w-full">
                <img
                  src="https://picsum.photos/800/400?random=1"
                  alt="Astro with Decap CMS"
                  class="w-full h-auto object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
              <div
                class="flex-1 flex flex-col justify-center px-6 pt-6 pb-8 bg-contentful-primary text-gray-900 text-center"
              >
                <h2 class="text-xl font-bold">Why Astro / Decap?</h2>
                <p class="mt-2">
                  Why Astro and Decap are a good fit for our projects
                </p>
                <div class="mt-6 flex justify-center">
                  <span
                    class="inline-flex items-center rounded-full bg-blue-100 px-3 py-0.5 text-sm font-medium text-blue-800"
                  >
                    <svg
                      class="mr-1.5 h-2 w-2 text-blue-400"
                      fill="currentColor"
                      viewBox="0 0 8 8"
                    >
                      <circle cx="4" cy="4" r="3"></circle>
                    </svg>
                    Guide
                  </span>
                </div>
              </div>
            </a>
          </div>

          <div
            class="transform transition duration-500 hover:scale-105 hover:shadow-xl"
          >
            <a
              href="/documentation/getting-started"
              class="flex flex-col overflow-hidden rounded-3xl shadow-md group"
            >
              <div class="relative w-full">
                <img
                  src="https://picsum.photos/800/400?random=2"
                  alt="Platonic Project"
                  class="w-full h-auto object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
              <div
                class="flex-1 flex flex-col justify-center px-6 pt-6 pb-8 bg-contentful-primary text-gray-900 text-center"
              >
                <h2 class="text-xl font-bold">Getting Started</h2>
                <p class="mt-2">
                  What to do when you get a new Platonic based project
                </p>
                <div class="mt-6 flex justify-center">
                  <span
                    class="inline-flex items-center rounded-full bg-blue-100 px-3 py-0.5 text-sm font-medium text-blue-800"
                  >
                    <svg
                      class="mr-1.5 h-2 w-2 text-blue-400"
                      fill="currentColor"
                      viewBox="0 0 8 8"
                    >
                      <circle cx="4" cy="4" r="3"></circle>
                    </svg>
                    Overview
                  </span>
                </div>
              </div>
            </a>
          </div>
        </div>
      </div>

      <!-- Additional Resources Section -->
      <div class="bg-gray-50">
        <div class="mx-auto max-w-7xl px-4 pt-18 pb-20 sm:px-6 lg:px-8">
          <div class="text-center">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900">
              Additional Resources
            </h2>
            <p class="mx-auto mt-3 max-w-2xl text-xl text-gray-500">
              Explore these resources to enhance your development experience.
            </p>
          </div>

          <div class="mt-10">
            <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
              <!-- Resource 1 -->
              <div
                class="group relative rounded-lg border border-gray-200 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg"
              >
                <div>
                  <span class="inline-flex rounded-lg bg-blue-50 p-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      class="h-6 w-6 text-blue-600"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
                      ></path>
                    </svg>
                  </span>
                </div>
                <div class="mt-4">
                  <h3 class="text-lg font-medium text-gray-900">
                    Official Astro Documentation
                  </h3>
                  <p class="mt-2 text-base text-gray-500">
                    Access the official documentation for Astro.js.
                  </p>
                </div>
                <div class="mt-6">
                  <a
                    href="https://docs.astro.build"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-base font-medium text-blue-600 hover:text-blue-500"
                  >
                    Learn more <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>

              <!-- Resource 2 -->
              <div
                class="group relative rounded-lg border border-gray-200 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg"
              >
                <div>
                  <span class="inline-flex rounded-lg bg-blue-50 p-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      class="h-6 w-6 text-blue-600"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"
                      ></path>
                    </svg>
                  </span>
                </div>
                <div class="mt-4">
                  <h3 class="text-lg font-medium text-gray-900">
                    Tailwind Plus
                  </h3>
                  <p class="mt-2 text-base text-gray-500">
                    Explore code examples and templates for common use cases.
                  </p>
                </div>
                <div class="mt-6">
                  <a
                    href="https://tailwindcss.com/plus/ui-blocks/marketing"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-base font-medium text-blue-600 hover:text-blue-500"
                  >
                    View examples <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>

              <!-- Resource 3 -->
              <div
                class="group relative rounded-lg border border-gray-200 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg"
              >
                <div>
                  <span class="inline-flex rounded-lg bg-blue-50 p-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      class="h-6 w-6 text-blue-600"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"
                      ></path>
                    </svg>
                  </span>
                </div>
                <div class="mt-4">
                  <h3 class="text-lg font-medium text-gray-900">
                    Running into build issues?
                  </h3>
                  <p class="mt-2 text-base text-gray-500">
                    Follow the guide on fixing build issues
                  </p>
                </div>
                <div class="mt-6">
                  <a
                    href="/documentation/fixing-build-issues"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-base font-medium text-blue-600 hover:text-blue-500"
                  >
                    Fix Build Issues <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ Section -->
      <div class="mx-auto max-w-7xl px-4 pt-20 pb-28 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900">
            Frequently Asked Questions
          </h2>
          <p class="mx-auto mt-3 max-w-2xl text-xl text-gray-500">
            Common questions about using Astro with Decap CMS.
          </p>
        </div>

        <div class="mt-12">
          <dl
            class="space-y-10 md:grid md:grid-cols-2 md:gap-x-8 md:gap-y-12 md:space-y-0"
          >
            <div>
              <dt class="text-lg font-medium leading-6 text-gray-900">
                What is Astro.js?
              </dt>
              <dd class="mt-2 text-base text-gray-500">
                Astro is a modern static site generator that allows you to build
                faster websites with less client-side JavaScript.
              </dd>
            </div>
            <div>
              <dt class="text-lg font-medium leading-6 text-gray-900">
                What is Decap CMS?
              </dt>
              <dd class="mt-2 text-base text-gray-500">
                Decap CMS (formerly Netlify CMS) is an open-source, Git-based
                content management system that provides a user-friendly
                interface for editing content.
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </main>
  </div>
</Layout>
