---
import Logo from '@assets/logo.png'
---

<header class="shrink-0 border-b border-gray-200 bg-white relative z-10">
  <div
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    <div class="flex lg:flex-1 items-center">
      <a href="/" class="-m-1.5 p-1.5">
        <span class="sr-only">Le Centre Franco</span>
        <img
          class="h-12 w-auto"
          src={Logo.src}
          alt="Le Centre Franco"
          title="Le Centre Franco"
        />
      </a>
      <h1 class="ms-6 text-3xl font-light">Platonic</h1>
    </div>
    <div class="flex items-center gap-x-8">
      <nav>
        <ul class="flex items-center space-x-8">
          <li>
            <a
              href="/documentation/getting-started"
              class="text-gray-700 hover:text-blue-600 font-medium"
            >
              Getting Started
            </a>
          </li>
          <li>
            <a
              href="/documentation/content-config"
              class="text-gray-700 hover:text-blue-600 font-medium"
            >
              Configuring Content
            </a>
          </li>
          <li>
            <a
              href="/documentation/useful-commands"
              class="text-gray-700 hover:text-blue-600 font-medium"
            >
              Useful Commands
            </a>
          </li>
          <li>
            <a
              href="/documentation/fixing-build-issues"
              class="text-gray-700 hover:text-blue-600 font-medium"
            >
              Fixing Build Issues
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>
