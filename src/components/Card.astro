---
interface Props {
  name: string
  courseCode: string
  description: string
  imageUrl: string
}

const { name, courseCode, description, imageUrl } = Astro.props
---

<li class="overflow-hidden rounded-xl border border-gray-200">
  <div
    class="flex items-center gap-x-4 border-b border-gray-900/5 bg-gray-50 p-6"
  >
    <img
      src={imageUrl}
      alt="Tuple"
      class="size-12 flex-none rounded-lg bg-white object-cover ring-1 ring-gray-900/10"
    />
    <div class="text-sm/6 font-medium text-gray-900">{name}</div>
  </div>
  <dl class="-my-3 divide-y divide-gray-100 px-6 py-4 text-sm/6">
    <div class="flex justify-between gap-x-4 py-3">
      <dt class="text-gray-500">Course Code</dt>
      <dd class="font-medium text-gray-700">{courseCode}</dd>
    </div>
    <div class="flex justify-between gap-x-4 py-3">
      <dt class="text-gray-500">Description</dt>
      <dd class="flex items-start gap-x-2">
        <div class="text-gray-900 text-right">{description}</div>
      </dd>
    </div>
  </dl>
</li>
